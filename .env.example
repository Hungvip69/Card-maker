# Copy to .env and fill in real values. Do NOT commit the .env file.

# Server port (default 3000)
PORT=3000

# Bind address (0.0.0.0 = allow other machines on the LAN to connect)
HOST=0.0.0.0

# KLIPY API key for GIF/sticker search — get one free at https://partner.klipy.com
# Without it, the /api/gif/search route returns 503; everything else still works.
KLIPY_KEY=

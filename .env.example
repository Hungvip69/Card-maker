# Sao chép thành .env rồi điền giá trị thật. KHÔNG commit file .env.

# Cổng server (mặc định 3000)
PORT=3000

# Địa chỉ bind (0.0.0.0 = cho phép máy khác trong LAN truy cập)
HOST=0.0.0.0

# API key KLIPY cho tính năng tìm GIF/sticker — lấy free tại https://partner.klipy.com
# Thiếu key thì route /api/gif/search trả 503, phần còn lại vẫn chạy.
KLIPY_KEY=
